# YouTube Data API v3 — create a project at console.cloud.google.com, enable the API, create an API key
YOUTUBE_API_KEY=your_youtube_api_key

# dev.to API key — get from dev.to/settings/extensions
DEVTO_API_KEY=your_devto_api_key

# GitHub Personal Access Token — get from github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=your_github_token

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
